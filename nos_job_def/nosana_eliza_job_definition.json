{
  "version": "0.1",
  "type": "container",
  "ops": [
    {
      "id": "agent",
      "type": "container/run",
      "args": {
        "image": "aminuayomide/ideaminer:latest",
        "expose": 3000,
        "env": {
          "OPENAI_API_KEY": "YOUR_GROQ_KEY",
          "OPENAI_BASE_URL": "https://api.groq.com/openai/v1",
          "OPENAI_SMALL_MODEL": "llama3-8b-8192",
          "OPENAI_LARGE_MODEL": "llama3-8b-8192",
          "TAVILY_API_KEY": "YOUR_TAVILY_KEY",
          "SERVER_PORT": "3000",
          "NODE_ENV": "production"
        }
      },
      "execution": {
        "group": "run"
      }
    }
  ]
}
